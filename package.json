{
  "name": "web-file-manager",
  "version": "1.0.0",
  "description": "轻量级 Web 文件管理器 — 支持文件浏览、上传下载、拖拽上传、图片缩略图、文本预览",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --skipLibCheck",
    "start": "node dist/server.js",
    "dev": "bash start.sh"
  },
  "keywords": ["file-manager", "web", "express", "typescript", "file-explorer"],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
